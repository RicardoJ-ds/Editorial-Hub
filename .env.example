# Copy this file to .env and fill in real values
# cp .env.example .env

# PostgreSQL
POSTGRES_DB=editorial_hub
POSTGRES_USER=editorial
POSTGRES_PASSWORD=changeme

# Backend
DATABASE_URL=postgresql+asyncpg://editorial:changeme@localhost:5432/editorial_hub
GOOGLE_APPLICATION_CREDENTIALS=sa-key.json
BQ_PROJECT=graphite-data
BQ_DATASET=graphite_bi_sandbox
CORS_ORIGINS=["http://localhost:4050"]

# Google Sheets IDs (required for migration/sync)
SPREADSHEET_ID=
MASTER_TRACKER_ID=
AI_MONITORING_ID=
NOTION_DATABASE_ID=

# Google Doc IDs for fetch_docs.py (comma-separated)
DOC_IDS=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8050

# Google OAuth (frontend sign-in — @graphitehq.com only)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs must include both the prod and local dev callback:
#   https://<your-vercel-domain>/api/auth/callback/google
#   http://localhost:4050/api/auth/callback/google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
AUTH_REDIRECT_URI=http://localhost:4050/api/auth/callback/google
# 32+ byte secret used to sign the session JWT. Generate with: openssl rand -base64 32
AUTH_SECRET=
# Restrict sign-in to this Google Workspace hosted domain
ALLOWED_EMAIL_DOMAIN=graphitehq.com

# --- Dashboard data source (warehouse architecture, 2026-06-11) ---
# The app SERVES from Postgres; BigQuery is the always-fresh analytics mirror
# (rebuilt by the "Publish warehouse" sync step + ./etl/refresh.sh).
# Set "bq" only for validation — see etl/WAREHOUSE_DESIGN.md.
DASHBOARD_SOURCE=postgres
# Honor the per-request X-Data-Source override (parity harness ONLY — keep
# false in production).
DATA_SOURCE_OVERRIDE_ENABLED=false

# Daily server-side sync (sheets -> Neon -> dual-sink warehouse publish).
# Enable in PROD so dashboards + BigQuery stay fresh without manual SYNC.
SYNC_CRON_ENABLED=false
SYNC_CRON_UTC_HOUR=9
