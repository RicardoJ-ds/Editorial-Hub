# Copy this file to .env and fill in real values
# cp .env.example .env

# PostgreSQL
POSTGRES_DB=editorial_hub
POSTGRES_USER=editorial
POSTGRES_PASSWORD=changeme

# Backend
DATABASE_URL=postgresql+asyncpg://editorial:changeme@localhost:5432/editorial_hub
GOOGLE_APPLICATION_CREDENTIALS=sa-key.json
BQ_PROJECT=graphite-data
BQ_DATASET=graphite_bi_sandbox
CORS_ORIGINS=["http://localhost:4050"]

# Google Sheets IDs (required for migration/sync)
SPREADSHEET_ID=
MASTER_TRACKER_ID=
AI_MONITORING_ID=

# Google Doc IDs for fetch_docs.py (comma-separated)
DOC_IDS=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8050
